# ============================================================================
#  Tender Agent — environment configuration
#  Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ============================================================================

# ── LLM models ──────────────────────────────────────────────────────────────
# Format for every model variable:  provider:model-id
# Supported providers: openai, anthropic, google_genai, perplexity
#
# Two roles:
#   classify — high volume, relevance check of every prefiltered tender.
#              A "mini"/"nano" model is the cost-efficient choice here.
#   report   — low volume, writes the Ukrainian summaries for new tenders only.
#
# NOTE: verify model IDs against your provider's current catalog before use.
LLM_CLASSIFY_PRIMARY=openai:gpt-5.4-mini
LLM_CLASSIFY_BACKUP=openai:gpt-5.4-nano
LLM_REPORT_PRIMARY=openai:gpt-5.5
LLM_REPORT_BACKUP=openai:gpt-5.4-mini

# ── Provider API keys ───────────────────────────────────────────────────────
# Only the keys for providers you actually use are required.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=

# ── Email (generic SMTP) ────────────────────────────────────────────────────
# Works with Gmail SMTP or any corporate mail server.
#   Gmail:     host=smtp.gmail.com  port=587  security=starttls
#              (use a Gmail "App password", not the account password)
#   Corporate: ask your mail admin for host / port / security.
# SMTP_SECURITY: starttls | ssl | none
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURITY=starttls
SMTP_USERNAME=
SMTP_PASSWORD=
# Address shown as the sender. Defaults to SMTP_USERNAME if left blank.
SMTP_FROM=

# ── Schedule ────────────────────────────────────────────────────────────────
# Cron expression for the daily run (minute hour day month weekday).
SCHEDULE_CRON=0 8 * * *
TIMEZONE=Europe/Kyiv
# Send an email even when there are no new tenders? (true/false)
SEND_WHEN_EMPTY=false

# ── Crawling ────────────────────────────────────────────────────────────────
PROZORRO_API_BASE=https://public-api.prozorro.gov.ua/api/2.5
# On the very first run, start crawling tenders modified within this many days.
CRAWL_LOOKBACK_DAYS=3
REQUEST_TIMEOUT_SECONDS=30
MAX_RETRIES=4

# ── Paths & logging ─────────────────────────────────────────────────────────
DATA_DIR=data
FILTERS_PATH=config/filters.yaml
RECIPIENTS_PATH=recipients.yaml
LOG_LEVEL=INFO
