<!DOCTYPE html>
<html lang="uk">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Звіт по тендерах — автохімія</title>
</head>
<body style="margin:0;padding:0;background-color:#f5f5f5;font-family:Arial,Helvetica,sans-serif;font-size:14px;color:#222222;line-height:1.5;">

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#f5f5f5;padding:24px 0;">
  <tr>
    <td align="center">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:640px;background-color:#ffffff;border-radius:6px;overflow:hidden;box-shadow:0 1px 4px rgba(0,0,0,0.08);">

        {# ── Header ── #}
        <tr>
          <td style="background-color:#1a3a5c;padding:28px 32px;">
            <p style="margin:0;font-size:20px;font-weight:bold;color:#ffffff;">
              Звіт по тендерах — автохімія
            </p>
            <p style="margin:8px 0 0;font-size:13px;color:#b8cfe4;">
              Дата формування: {{ date_str }}&nbsp;&nbsp;|&nbsp;&nbsp;Нових тендерів: {{ total }}
            </p>
          </td>
        </tr>

        {# ── Body ── #}
        <tr>
          <td style="padding:24px 32px;">

            {% for section in sections %}
            {# ── Category heading ── #}
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-bottom:8px;">
              <tr>
                <td style="border-left:4px solid #1a3a5c;padding:6px 12px;background-color:#eef3f8;">
                  <p style="margin:0;font-size:15px;font-weight:bold;color:#1a3a5c;">{{ section.label }}</p>
                </td>
              </tr>
            </table>

            {% for ct in section.tenders %}
            {# ── Tender card ── #}
            <table role="presentation" width="100%" cellpadding="0" cellspacing="0"
                   style="margin-bottom:20px;border:1px solid #dde4ec;border-radius:4px;overflow:hidden;">

              {# Title row #}
              <tr>
                <td style="padding:14px 16px 8px;background-color:#f8fafc;">
                  <p style="margin:0;font-size:14px;font-weight:bold;color:#111111;">
                    {{ ct.tender.title or "(без назви)" }}
                  </p>
                </td>
              </tr>

              {# Link + ID row #}
              <tr>
                <td style="padding:4px 16px 10px;background-color:#f8fafc;border-bottom:1px solid #dde4ec;">
                  <a href="{{ ct.tender.web_url }}"
                     style="font-size:13px;color:#1a5fa8;text-decoration:none;font-weight:bold;">
                    Відкрити на Prozorro &rarr;
                  </a>
                  <span style="margin-left:12px;font-size:12px;color:#666666;">{{ ct.tender.public_id }}</span>
                </td>
              </tr>

              {# Details #}
              <tr>
                <td style="padding:12px 16px;">
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0">

                    {# Procuring entity #}
                    {% if ct.tender.procuringEntity and ct.tender.procuringEntity.name %}
                    <tr>
                      <td style="padding:3px 0;width:160px;font-size:12px;color:#666666;vertical-align:top;">Замовник:</td>
                      <td style="padding:3px 0;font-size:13px;color:#222222;vertical-align:top;">{{ ct.tender.procuringEntity.name }}</td>
                    </tr>
                    {% endif %}

                    {# Expected value #}
                    {% if ct.tender.value and ct.tender.value.amount is not none %}
                    <tr>
                      <td style="padding:3px 0;width:160px;font-size:12px;color:#666666;vertical-align:top;">Очікувана вартість:</td>
                      <td style="padding:3px 0;font-size:13px;color:#222222;vertical-align:top;">
                        {{ "{:,.2f}".format(ct.tender.value.amount) | replace(",", " ") }}
                        {{ ct.tender.value.currency or "" }}
                      </td>
                    </tr>
                    {% endif %}

                    {# Bidding deadline #}
                    {% if ct.tender.tenderPeriod and ct.tender.tenderPeriod.endDate %}
                    <tr>
                      <td style="padding:3px 0;width:160px;font-size:12px;color:#666666;vertical-align:top;">Кінець подання:</td>
                      <td style="padding:3px 0;font-size:13px;color:#222222;vertical-align:top;">
                        {%- set raw_date = ct.tender.tenderPeriod.endDate -%}
                        {%- set formatted = raw_date | format_end_date -%}
                        {{ formatted }}
                      </td>
                    </tr>
                    {% endif %}

                    {# Classification codes #}
                    {%- set codes = ct.tender.classification_codes() -%}
                    {% if codes %}
                    <tr>
                      <td style="padding:3px 0;width:160px;font-size:12px;color:#666666;vertical-align:top;">ДК 021:2015:</td>
                      <td style="padding:3px 0;font-size:13px;color:#222222;vertical-align:top;">{{ codes | join(", ") }}</td>
                    </tr>
                    {% endif %}

                  </table>

                  {# LLM summary #}
                  {% if ct.summary %}
                  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="margin-top:10px;">
                    <tr>
                      <td style="padding:10px 12px;background-color:#f0f5fb;border-left:3px solid #1a5fa8;border-radius:2px;">
                        <p style="margin:0 0 4px;font-size:11px;font-weight:bold;color:#1a5fa8;text-transform:uppercase;letter-spacing:0.5px;">Аналіз</p>
                        <p style="margin:0;font-size:13px;color:#333333;">{{ ct.summary }}</p>
                      </td>
                    </tr>
                  </table>
                  {% endif %}

                </td>
              </tr>

            </table>
            {% endfor %}{# end tenders #}

            {% endfor %}{# end sections #}

          </td>
        </tr>

        {# ── Footer ── #}
        <tr>
          <td style="padding:16px 32px 24px;border-top:1px solid #dde4ec;">
            <p style="margin:0;font-size:11px;color:#888888;">
              Цей звіт сформовано автоматично агентом моніторингу тендерів.
              Перейдіть за посиланням до кожного тендеру на сайті Prozorro, щоб переконатися в актуальності та повноті даних.
            </p>
          </td>
        </tr>

      </table>
    </td>
  </tr>
</table>

</body>
</html>
